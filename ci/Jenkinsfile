pipeline {
  agent any

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '10'))
  }

  parameters {
    choice(
      name: 'ENVIRONMENT',
      choices: ['dev', 'staging', 'production'],
      description: 'Target deployment environment'
    )
    string(
      name: 'VERSION',
      defaultValue: '1.0.0',
      description: 'Application version to deploy'
    )
    booleanParam(
      name: 'SIMULATE_FAILURE',
      defaultValue: false,
      description: 'Tick this to simulate a pipeline failure for demo'
    )
    booleanParam(
      name: 'SEED_FAKE_SECRET',
      defaultValue: false,
      description: 'Tick this to seed a fake secret and prove scanning catches it'
    )

   }

  environment {
    APP_NAME      = 'training-site'
    IMAGE_TAG     = "training-site:${params.VERSION}"
    NOTIFY_EMAIL  = 'sjmandal2415@gmail.com'
    TWILIO_SID    = credentials('twilio-account-sid')
    TWILIO_TOKEN  = credentials('twilio-auth-token')
    TWILIO_FROM   = '+15187213926'   
    TWILIO_TO     = '+917991172794'
    TRELLO_KEY      = credentials('trello-api-key')
    TRELLO_TOKEN    = credentials('trello-token')
    TRELLO_LIST_ID  = credentials('trello-list-id')
    MINIKUBE_HOME = '/home/webadmin'
    KUBECONFIG    = '/home/webadmin/.kube/config'
    DOCKER_HOST   = 'unix:///var/run/docker.sock'
    PATH          = "/usr/local/bin:/usr/bin:/bin:${env.PATH}" 
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Seed fake secret (demo only)') {
      when {
        expression { params.SEED_FAKE_SECRET == true }
      }
      steps {
        sh '''
          echo "Seeding fake secret for scanning demo..."
          cat > fake-secret-demo.txt <<SECRETEOF
FAKE_AWS_KEY=AKIAIOSFODNN7EXAMPLE
FAKE_AWS_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
FAKE_GITHUB_TOKEN=ghp_FakeTokenForTestingPurposesOnly12345
SECRETEOF
          echo "Fake secret seeded."
        '''
      }
    }

    
    stage('Secret scanning') {
      steps {
        sh '''
          echo "=== Secret scanning with Gitleaks ==="
          gitleaks detect --source . \
            --config .gitleaks.toml \
            --report-format json \
            --report-path gitleaks-report.json \
            --no-git \
            --exit-code 0 || true

          FINDINGS=$(cat gitleaks-report.json | python3 -c "import sys,json; data=json.load(sys.stdin); print(len(data))" 2>/dev/null || echo "0")
          echo "Gitleaks findings: ${FINDINGS}"

          if [ "${FINDINGS}" -gt "0" ]; then
            echo "CRITICAL: Secrets detected in codebase!"
            cat gitleaks-report.json
            exit 1
          fi
          echo "Secret scan PASSED - no secrets detected"
        '''
      }
    }



    stage('Lint') {
      steps {
        sh '''
          echo "=== Lint stage ==="
          echo "Environment : $ENVIRONMENT"
          echo "Version     : $VERSION"
          make lint
        '''
      }
    }

    stage('Build Docker image') {
      steps {
        sh '''
          echo "=== Build Docker Image stage ==="
          echo "Building version: $VERSION for environment: $ENVIRONMENT"
          docker build -f docker/Dockerfile -t training-site:$VERSION .
        '''
      }
    }

    stage('Image scanning') {
      steps {
        sh """
            echo "=== Image scanning with Trivy ==="
            export MINIKUBE_HOME=/home/webadmin
            export KUBECONFIG=/home/webadmin/.kube/config

            # Set docker env from minikube
            eval \$(minikube docker-env --shell bash) || true

            trivy image ${env.IMAGE_TAG} \\
                --severity HIGH,CRITICAL \\
                --format json \\
                --output trivy-image-report.json \\
                --exit-code 0 || true

            CRITICAL_COUNT=\$(cat trivy-image-report.json | \\
                python3 -c "
import sys, json
data = json.load(sys.stdin)
count = 0
for result in data.get('Results', []):
    for vuln in result.get('Vulnerabilities', []):
        if vuln.get('Severity') == 'CRITICAL':
            count += 1
print(count)
" 2>/dev/null || echo "0")

            echo "Critical vulnerabilities: \${CRITICAL_COUNT}"

            if [ "\${CRITICAL_COUNT}" -gt "10" ]; then
                echo "CRITICAL: Too many vulnerabilities!"
                exit 1
            fi
            echo "Image scan PASSED"
        """
    }
}

    stage('Dependency scanning') {
      steps {
        sh '''
          echo "=== Dependency scanning with Trivy ==="
          trivy fs . \
            --severity HIGH,CRITICAL \
            --format json \
            --output trivy-fs-report.json \
            --exit-code 0
          echo "Dependency scan complete"
        '''
      }
    }




    stage('Test') {
      steps {
        sh '''
          echo "=== Test stage ==="
          make test
        '''
      }
    }

    stage('Run DB Migration') {
      steps {
        sh '''
          echo "=== Running DB Migration v2.0.0 ==="
          kubectl delete job training-site-migration-v2 -n dev --force 2>/dev/null || true
          kubectl delete configmap migration-v2-script -n dev 2>/dev/null || true

          sleep 5          


          kubectl apply -f k8s/base/migration-configmap.yaml -n dev --validate=false
          kubectl apply -f k8s/base/migration-job.yaml -n dev  --validate=false

          echo "Waiting for migration job to complete..."
          kubectl wait --for=condition=complete \
          job/training-site-migration-v2 \
          -n dev \
          --timeout=120s

          echo "Migration status:"
          kubectl get job training-site-migration-v2 -n dev

          echo "Migration logs:"
          kubectl logs -l type=migration -n dev --tail=20

          echo "=== Migration completed ==="
          '''
           }
         }




    stage('Simulate failure') {
      steps {
        script {
          if (params.SIMULATE_FAILURE) {
            error("Simulated failure triggered intentionally for Day 14 demo")
          } else {
            echo "SIMULATE_FAILURE is false. Skipping failure simulation."
          }
        }
      }
    }

    stage('Publish artifacts') {
      steps {
        sh '''
          echo "=== Publish artifacts stage ==="
          mkdir -p logs
          echo "Build: ${BUILD_NUMBER} | Version: ${VERSION} | Env: ${ENVIRONMENT}" > logs/day14-build-info.txt
        '''
        archiveArtifacts artifacts: 'logs/**,build/**', allowEmptyArchive: true
      }
    }

    stage('Notify') {
      steps {
        echo "=== Notification stage ==="
        echo "Build ${env.BUILD_NUMBER} completed."
        echo "Version    : ${params.VERSION}"
        echo "Environment: ${params.ENVIRONMENT}"
      }
    }
  }

  post {
    success {
      echo "========================================="
      echo "Pipeline SUCCEEDED"
      echo "========================================="

      // 1. Email notification
      mail(
        to: "${env.NOTIFY_EMAIL}",
        subject: "SUCCESS: ${env.JOB_NAME} - Build #${env.BUILD_NUMBER}",
        body: """
Pipeline passed successfully.

Job        : ${env.JOB_NAME}
Build      : ${env.BUILD_NUMBER}
Version    : ${params.VERSION}
Environment: ${params.ENVIRONMENT}
Build URL  : ${env.BUILD_URL}
        """
      )

      // 2. Slack notification
      slackSend(
        channel: '#jenkins-alerts',
        color: 'good',
        message: """
*Pipeline PASSED* :white_check_mark:
*Job*        : ${env.JOB_NAME}
*Build*      : #${env.BUILD_NUMBER}
*Version*    : ${params.VERSION}
*Environment*: ${params.ENVIRONMENT}
*URL*        : ${env.BUILD_URL}
        """
      )

      // 3. Twilio SMS notification
      sh """
        curl -X POST https://api.twilio.com/2010-04-01/Accounts/${TWILIO_SID}/Messages.json \\
        --data-urlencode "Body=JENKINS PASSED: ${env.JOB_NAME} #${env.BUILD_NUMBER} | Version: ${params.VERSION} | Env: ${params.ENVIRONMENT}" \\
        --data-urlencode "From=${TWILIO_FROM}" \\
        --data-urlencode "To=${TWILIO_TO}" \\
        -u "${TWILIO_SID}:${TWILIO_TOKEN}"
      """
    }

    failure {
      echo "========================================="
      echo "Pipeline FAILED"
      echo "========================================="

      // 1. Email notification
      mail(
        to: "${env.NOTIFY_EMAIL}",
        subject: "FAILED: ${env.JOB_NAME} - Build #${env.BUILD_NUMBER}",
        body: """
Pipeline has FAILED.

Job        : ${env.JOB_NAME}
Build      : ${env.BUILD_NUMBER}
Version    : ${params.VERSION}
Environment: ${params.ENVIRONMENT}
Build URL  : ${env.BUILD_URL}

Please check the logs immediately.
        """
      )

      // 2. Slack notification
      slackSend(
        channel: '#jenkins-alerts',
        color: 'danger',
        message: """
*Pipeline FAILED* :x:
*Job*        : ${env.JOB_NAME}
*Build*      : #${env.BUILD_NUMBER}
*Version*    : ${params.VERSION}
*Environment*: ${params.ENVIRONMENT}
*URL*        : ${env.BUILD_URL}
Please check the logs immediately!
        """
      )

      // 3. Twilio SMS notification
      sh """
        curl -X POST https://api.twilio.com/2010-04-01/Accounts/${TWILIO_SID}/Messages.json \\
        --data-urlencode "Body=JENKINS FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER} | Version: ${params.VERSION} | Env: ${params.ENVIRONMENT} | Check immediately!" \\
        --data-urlencode "From=${TWILIO_FROM}" \\
        --data-urlencode "To=${TWILIO_TO}" \\
        -u "${TWILIO_SID}:${TWILIO_TOKEN}"
      """
    

    // 4. Trello card creation
      httpRequest(
      url: "https://api.trello.com/1/cards",
      httpMode: 'POST',
      requestBody: """
        {
          "name": "BUILD FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
          "desc": "Pipeline failed. Check: ${env.BUILD_URL}",
          "idList": "${env.TRELLO_LIST_ID}",
          "key": "${env.TRELLO_KEY}",
          "token": "${env.TRELLO_TOKEN}"
        }
      """,
      contentType: 'APPLICATION_JSON'
    )

      }

    always {
      echo "Cleaning workspace..."
      cleanWs()
    }
  }
}

