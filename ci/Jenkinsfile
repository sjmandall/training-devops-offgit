pipeline {
  agent any

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '10'))
  }

  parameters {
    choice(
      name: 'ENVIRONMENT',
      choices: ['dev', 'staging', 'production'],
      description: 'Target deployment environment'
    )
    string(
      name: 'VERSION',
      defaultValue: '1.0.0',
      description: 'Application version to deploy'
    )
    booleanParam(
      name: 'SIMULATE_FAILURE',
      defaultValue: false,
      description: 'Tick this to simulate a pipeline failure for demo'
    )
  }

  environment {
    APP_NAME  = 'training-site'
    IMAGE_TAG = "training-site:${params.VERSION}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Lint') {
      steps {
        sh '''
          echo "=== Lint stage ==="
          echo "Environment : $ENVIRONMENT"
          echo "Version     : $VERSION"
          make lint
        '''
      }
    }

    stage('Build Docker image') {
      steps {
        sh '''
          echo "=== Build Docker Image stage ==="
          echo "Building version: $VERSION for environment: $ENVIRONMENT"
          docker build -f docker/Dockerfile -t training-site:$VERSION .
        '''
      }
    }

    stage('Test') {
      steps {
        sh '''
          echo "=== Test stage ==="
          make test
        '''
      }
    }

    stage('Simulate failure') {
      steps {
        script {
          if (params.SIMULATE_FAILURE) {
            error("Simulated failure triggered intentionally for Day 14 demo")
          } else {
            echo "SIMULATE_FAILURE is false. Skipping failure simulation."
          }
        }
      }
    }

    stage('Publish artifacts') {
      steps {
        sh '''
          echo "=== Publish artifacts stage ==="
          mkdir -p logs
          echo "Build: ${BUILD_NUMBER} | Version: ${VERSION} | Env: ${ENVIRONMENT}" > logs/day14-build-info.txt
        '''
        archiveArtifacts artifacts: 'logs/**,build/**', allowEmptyArchive: true
      }
    }

    stage('Notify') {
      steps {
        echo "=== Notification stage ==="
        echo "Build ${env.BUILD_NUMBER} completed."
        echo "Version   : ${params.VERSION}"
        echo "Environment: ${params.ENVIRONMENT}"
        echo "Notification placeholder: In production this would send a Slack or email alert to the team."
      }
    }
  }

  post {
    success {
      echo "========================================="
      echo "Pipeline SUCCEEDED"
      echo "Job       : ${env.JOB_NAME}"
      echo "Build     : ${env.BUILD_NUMBER}"
      echo "Version   : ${params.VERSION}"
      echo "Environment: ${params.ENVIRONMENT}"
      echo "========================================="
    }
    failure {
      echo "Pipeline FAILED"
      mail(
        to: 'sjmandal2415@gmail.com',
        subject: "FAILED: Job ${env.JOB_NAME} Build ${env.BUILD_NUMBER}"
        body: """
           Pipelined failed.
            Job       : ${env.JOB_NAME}
            Build     : ${env.BUILD_NUMBER}
            Version   : ${params.VERSION}
            Environment: ${params.ENVIRONMENT}
            Check logs: ${env.BUILD_URL}
            """
      )
      echo "Job       : ${env.JOB_NAME}"
      echo "Build     : ${env.BUILD_NUMBER}"
      echo "Version   : ${params.VERSION}"
      echo "Environment: ${params.ENVIRONMENT}"
      echo "Notification placeholder: Alert team about this failure."
      echo "========================================="
    }
    always {
      echo "Cleaning workspace..."
      cleanWs()
    }
  }
}

