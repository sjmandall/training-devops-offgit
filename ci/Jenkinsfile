pipeline {
  agent any

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '10'))
  }

  parameters {
    choice(
      name: 'ENVIRONMENT',
      choices: ['dev', 'staging', 'production'],
      description: 'Target deployment environment'
    )
    string(
      name: 'VERSION',
      defaultValue: '1.0.0',
      description: 'Application version to deploy'
    )
    booleanParam(
      name: 'SIMULATE_FAILURE',
      defaultValue: false,
      description: 'Tick this to simulate a pipeline failure for demo'
    )
  }

  environment {
    APP_NAME      = 'training-site'
    IMAGE_TAG     = "training-site:${params.VERSION}"
    NOTIFY_EMAIL  = 'sjmandal2415@gmail.com'
    TWILIO_SID    = credentials('twilio-account-sid')
    TWILIO_TOKEN  = credentials('twilio-auth-token')
    TWILIO_FROM   = '+15187213926'   
    TWILIO_TO     = '+917991172794'
    TRELLO_KEY      = credentials('trello-api-key')
    TRELLO_TOKEN    = credentials('trello-token')
    TRELLO_LIST_ID  = credentials('trello-list-id') 
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Lint') {
      steps {
        sh '''
          echo "=== Lint stage ==="
          echo "Environment : $ENVIRONMENT"
          echo "Version     : $VERSION"
          make lint
        '''
      }
    }

    stage('Build Docker image') {
      steps {
        sh '''
          echo "=== Build Docker Image stage ==="
          echo "Building version: $VERSION for environment: $ENVIRONMENT"
          docker build -f docker/Dockerfile -t training-site:$VERSION .
        '''
      }
    }

    stage('Test') {
      steps {
        sh '''
          echo "=== Test stage ==="
          make test
        '''
      }
    }

    stage('Simulate failure') {
      steps {
        script {
          if (params.SIMULATE_FAILURE) {
            error("Simulated failure triggered intentionally for Day 14 demo")
          } else {
            echo "SIMULATE_FAILURE is false. Skipping failure simulation."
          }
        }
      }
    }

    stage('Publish artifacts') {
      steps {
        sh '''
          echo "=== Publish artifacts stage ==="
          mkdir -p logs
          echo "Build: ${BUILD_NUMBER} | Version: ${VERSION} | Env: ${ENVIRONMENT}" > logs/day14-build-info.txt
        '''
        archiveArtifacts artifacts: 'logs/**,build/**', allowEmptyArchive: true
      }
    }

    stage('Notify') {
      steps {
        echo "=== Notification stage ==="
        echo "Build ${env.BUILD_NUMBER} completed."
        echo "Version    : ${params.VERSION}"
        echo "Environment: ${params.ENVIRONMENT}"
      }
    }
  }

  post {
    success {
      echo "========================================="
      echo "Pipeline SUCCEEDED"
      echo "========================================="

      // 1. Email notification
      mail(
        to: "${env.NOTIFY_EMAIL}",
        subject: "SUCCESS: ${env.JOB_NAME} - Build #${env.BUILD_NUMBER}",
        body: """
Pipeline passed successfully.

Job        : ${env.JOB_NAME}
Build      : ${env.BUILD_NUMBER}
Version    : ${params.VERSION}
Environment: ${params.ENVIRONMENT}
Build URL  : ${env.BUILD_URL}
        """
      )

      // 2. Slack notification
      slackSend(
        channel: '#jenkins-alerts',
        color: 'good',
        message: """
*Pipeline PASSED* :white_check_mark:
*Job*        : ${env.JOB_NAME}
*Build*      : #${env.BUILD_NUMBER}
*Version*    : ${params.VERSION}
*Environment*: ${params.ENVIRONMENT}
*URL*        : ${env.BUILD_URL}
        """
      )

      // 3. Twilio SMS notification
      sh """
        curl -X POST https://api.twilio.com/2010-04-01/Accounts/${TWILIO_SID}/Messages.json \\
        --data-urlencode "Body=JENKINS PASSED: ${env.JOB_NAME} #${env.BUILD_NUMBER} | Version: ${params.VERSION} | Env: ${params.ENVIRONMENT}" \\
        --data-urlencode "From=${TWILIO_FROM}" \\
        --data-urlencode "To=${TWILIO_TO}" \\
        -u "${TWILIO_SID}:${TWILIO_TOKEN}"
      """
    }

    failure {
      echo "========================================="
      echo "Pipeline FAILED"
      echo "========================================="

      // 1. Email notification
      mail(
        to: "${env.NOTIFY_EMAIL}",
        subject: "FAILED: ${env.JOB_NAME} - Build #${env.BUILD_NUMBER}",
        body: """
Pipeline has FAILED.

Job        : ${env.JOB_NAME}
Build      : ${env.BUILD_NUMBER}
Version    : ${params.VERSION}
Environment: ${params.ENVIRONMENT}
Build URL  : ${env.BUILD_URL}

Please check the logs immediately.
        """
      )

      // 2. Slack notification
      slackSend(
        channel: '#jenkins-alerts',
        color: 'danger',
        message: """
*Pipeline FAILED* :x:
*Job*        : ${env.JOB_NAME}
*Build*      : #${env.BUILD_NUMBER}
*Version*    : ${params.VERSION}
*Environment*: ${params.ENVIRONMENT}
*URL*        : ${env.BUILD_URL}
Please check the logs immediately!
        """
      )

      // 3. Twilio SMS notification
      sh """
        curl -X POST https://api.twilio.com/2010-04-01/Accounts/${TWILIO_SID}/Messages.json \\
        --data-urlencode "Body=JENKINS FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER} | Version: ${params.VERSION} | Env: ${params.ENVIRONMENT} | Check immediately!" \\
        --data-urlencode "From=${TWILIO_FROM}" \\
        --data-urlencode "To=${TWILIO_TO}" \\
        -u "${TWILIO_SID}:${TWILIO_TOKEN}"
      """
    }

    // 4. Trello card creation
      httpRequest(
      url: "https://api.trello.com/1/cards",
      httpMode: 'POST',
      requestBody: """
        {
          "name": "BUILD FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
          "desc": "Pipeline failed. Check: ${env.BUILD_URL}",
          "idList": "${env.TRELLO_LIST_ID}",
          "key": "${env.TRELLO_KEY}",
          "token": "${env.TRELLO_TOKEN}"
        }
      """,
      contentType: 'APPLICATION_JSON'
    )

    always {
      echo "Cleaning workspace..."
      cleanWs()
    }
  }
}
